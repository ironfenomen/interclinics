# .env.local — СКОПИРУЙТЕ ЭТОТ ФАЙЛ И ПЕРЕИМЕНУЙТЕ В .env.local

# ============================================================
# TELEGRAM — карточки лидов + webhook callback_query
# ============================================================
TG_BOT_TOKEN=ваш_токен_бота
TG_CHAT_ID=ваш_chat_id
# Пока webhook/кнопки не настроены — отключить пинги в группу и тик тревоги:
# LEAD_ALARM_DISABLED=1
# Секрет для setWebhook (заголовок X-Telegram-Bot-Api-Secret-Token, побайтово как secret_token). Пусто = без проверки.
# Если задан здесь, а в setWebhook другой/пустой — POST webhook вернёт 403, карточки от sendMessage придут, кнопки «молчат».
# Прокси должен пробрасывать X-Telegram-Bot-Api-Secret-Token на Node.
# TG_WEBHOOK_SECRET=
#
# Диагностика на бою: GET /api/telegram/webhook/diagnose с Authorization: Bearer CRON_SECRET
# (allowed_updates должен включать callback_query или быть не задан).
# Перерегистрация webhook: npm run telegram:set-webhook (env TELEGRAM_WEBHOOK_BASE_URL, TG_BOT_TOKEN, опц. TG_WEBHOOK_SECRET)

# SQLite лиды (по умолчанию ./data/leads.db). На serverless без диска — вынести в Postgres позже.
# LEADS_SQLITE_PATH=

# Тревога по новым заявкам (пинг + повтор каждые 30 с, пока статус new)
# TG_ALARM_GROUP_USER_IDS=123456789,987654321
# TG_ALARM_GROUP_USERNAMES=operator1,operator2
# TG_ALARM_DM_USER_IDS=123456789
# TG_ALARM_KEY_DM_USER_IDS=
# Отключить планировщик в процессе: LEAD_ALARM_DISABLED=1
# Резерв: GET /api/cron/lead-alarm с Authorization: Bearer CRON_SECRET (каждые 30 с)
# CRON_SECRET=
#
# Ежедневные сводки follow-up в Telegram (10:00 и 18:00 МСК — внешний cron, см. ниже)
# GET /api/cron/daily-digest?slot=10  и  ?slot=18  — тот же CRON_SECRET (Bearer или ?secret=)
# Чат по умолчанию TG_CHAT_ID; отдельно: TG_DIGEST_CHAT_ID=
# МСК = UTC+3: 10:00 МСК → 07:00 UTC, 18:00 МСК → 15:00 UTC
# TG_DIGEST_CHAT_ID=
#
# Недельная / месячная статистика воронки (те же CRON_SECRET и chat по умолчанию)
# GET /api/cron/weekly-stats — лучше по пн ~09:00 МСК (отчёт за прошлую пн–вс)
# GET /api/cron/monthly-stats — лучше 1-го ~09:00 МСК (за прошлый месяц)
# Отдельный чат: TG_STATS_CHAT_ID=
# TG_STATS_CHAT_ID=

# ============================================================
# AMOCRM — интеграция с CRM
# ============================================================
# AMO_DOMAIN=ваш_поддомен
# AMO_TOKEN=ваш_токен
# AMO_PHONE_FIELD=12345
# AMO_CITY_FIELD=12346
# AMO_SOURCE_FIELD=12347

# ============================================================
# CALLTOUCH — коллтрекинг (скрипт подключается в layout.tsx)
# ============================================================
# NEXT_PUBLIC_CALLTOUCH_ID=xxxxx

# ============================================================
# ЯНДЕКС МЕТРИКА (скрипт подключается в layout.tsx)
# ============================================================
# NEXT_PUBLIC_YM_ID=12345678
